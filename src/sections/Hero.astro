---
import { Button } from '@/components/ui/button';
import type { Gym } from '@/config/gyms';
import { Image } from 'astro:assets';
import { Star } from 'lucide-react';

interface Props {
  gym: Gym;
}

const { gym } = Astro.props;
const { hero, testimonials } = gym;
---

<section id="home" class="pt-32">
  <div class="container">
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <!-- Content -->
      <div class="space-y-6">
        <h1 class="text-5xl md:text-6xl font-bold leading-tight">
          {hero.heading}
          <span class="text-primary"> {hero.headingHighlight}</span>
        </h1>

        <p class="text-xl">{hero.subheading}</p>

        <div class="flex gap-4 flex-wrap pt-4">
          <Button className="w-full md:w-fit" size={'lg'}>
            <a href="#contact">{hero.cta}</a>
          </Button>
          <Button className="w-full md:w-fit" variant={'outline'} size={'lg'}>
            <a href="#services">View Services</a>
          </Button>
        </div>

        <ul class="space-y-3 pt-6">
          {
            hero.stats.map((stat) => (
              <li class="flex items-center gap-2">
                <span class="text-primary font-bold">✓</span>
                {stat}
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Image -->
      <div class="relative">
        <div class="bg-linear-to-br from-primary/20 to-slate rounded-2xl">
          <Image
            class="w-full rounded-2xl aspect-square object-cover"
            src={gym.heroImage}
            alt={`${gym.name} Hero`}
            width={600}
            height={600}
          />
        </div>
      </div>
    </div>
  </div>

  <div
    class="container space-y-3 md:space-y-0 md:grid md:grid-cols-3 md:gap-6 mt-25"
  >
    {
      testimonials.map((testimonial) => (
        <div class="bg-slate border-[1.5px] border-gray-700 rounded-lg p-6 hover:border-primary/80 transition-colors">
          <div class="flex gap-1 mb-4">
            {[...Array(5)].map(() => (
              <Star className="text-primary fill-primary" />
            ))}
          </div>
          <p class="mb-4">"{testimonial.text}"</p>
          <p class="font-semibold">
            - {testimonial.author}, {testimonial.duration}
          </p>
        </div>
      ))
    }
  </div>
</section>
