---
import { Button } from '@/components/ui/button';
import type { Gym } from '@/config/gyms';

interface Props {
  gym: Gym;
}

const { gym } = Astro.props;
const { services } = gym;
---

<section id="services" class="pt-30 pb-20 bg-card/50">
  <div class="container">
    <div class="text-center max-w-[800px] mx-auto mb-16">
      <h2 class="text-4xl leading-[1.3] font-bold mb-2 md:text-5xl">
        {services.heading}
      </h2>
      <p class="text-lg text-muted-foreground">{services.subheading}</p>
    </div>

    <div class="md:grid md:grid-cols-2 md:gap-8">
      {
        services.items.map((service) => (
          <div class="bg-card border-[1.5px] border-border rounded-xl p-8 hover:border-primary/70 transition-colors">
            <div class="flex items-center gap-3 mb-4">
              <div class="size-12 bg-primary/20 rounded-lg flex items-center justify-center text-2xl">
                {service.emoji}
              </div>
              <h3 class="text-2xl font-bold">{service.title}</h3>
            </div>

            <p class="text-muted-foreground mb-6">{service.description}</p>

            <ul class="space-y-3 text-muted-foreground mb-8">
              {service.features.map((feature) => (
                <li class="flex items-center gap-2">
                  <span>•</span>
                  {feature}
                </li>
              ))}
            </ul>

            <p class="text-2xl font-bold mb-6">
              <span class="text-primary">{service.price}</span>/
              {service.priceUnit}
            </p>

            <Button className="w-full" size={'lg'}>
              <a href="#contact">Get Started</a>
            </Button>
          </div>
        ))
      }
    </div>
  </div>
</section>
