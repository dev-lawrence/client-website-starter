---
import { Instagram, Twitter, Facebook } from 'lucide-react';
const { gym } = Astro.props;
---

<footer class="bg-card border-t border-border py-12">
  <div class="container">
    <div class="md:grid space-y-4 md:space-y-0 md:grid-cols-4 md:gap-8 mb-12">
      <!-- column 1 -->
      <div>
        <h3 class="text-xl font-bold text-primary mb-4">
          {gym.name}
        </h3>
        <p class="text-muted-foreground text-sm">
          Personal training and online coaching for sustainable results.
        </p>
      </div>

      <!-- column 2 -->
      <div>
        <h4 class="font-semibold mb-4">Quick Links</h4>
        <ul class="space-y-2 text-muted-foreground text-sm">
          <li>
            <a class="hover:text-primary transition-colors" href="#services"
              >Services</a
            >
          </li>
          <li>
            <a class="hover:text-primary transition-colors" href="#results"
              >Results</a
            >
          </li>
          <li>
            <a class="hover:text-primary transition-colors" href="#about"
              >About</a
            >
          </li>
        </ul>
      </div>

      <!-- column 3 -->
      <div>
        <h4 class="font-semibold mb-4">Contact</h4>
        <ul class="space-y-2 text-muted-foreground text-sm">
          <li>Email: {gym.email}</li>
          <li>Phone: {gym.phone}</li>
          <li>Address: {gym.address}</li>
        </ul>
      </div>

      <!-- column 4 -->
      <div>
        <h4 class="font-semibold mb-4">Follow</h4>
        <div class="flex gap-4">
          {
            gym.socials.instagram && (
              <a
                href={gym.socials.instagram}
                class="border-[1.5px] border-primary hover:text-white p-2 rounded-lg hover:bg-primary transition-colors"
              >
                <Instagram className="size-5" />
              </a>
            )
          }

          {
            gym.socials.twitter && (
              <a
                href={gym.socials.twitter}
                class="border-[1.5px] border-primary hover:text-white p-2 rounded-lg hover:bg-primary transition-colors"
              >
                <Twitter className="size-5" />
              </a>
            )
          }
        </div>
      </div>
    </div>

    <div
      class="border-t border-border pt-8 text-center text-muted-foreground text-sm"
    >
      <p>
        © {new Date().getFullYear()}
        {gym.name}. All rights reserved.
      </p>
    </div>
  </div>
</footer>
